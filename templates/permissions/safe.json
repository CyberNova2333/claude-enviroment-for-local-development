{
  "_desc": "safe —— 最保守：仅放行纯只读命令，任何写/网络/删除都要问",
  "permissions": {
    "allow": [
      "Bash(ls:*)", "Bash(cat:*)", "Bash(pwd)", "Bash(echo:*)",
      "Bash(grep:*)", "Bash(rg:*)", "Bash(find:*)", "Bash(head:*)", "Bash(tail:*)",
      "Bash(git status:*)", "Bash(git log:*)", "Bash(git diff:*)", "Bash(git show:*)",
      "Bash(clenv env doctor)", "Bash(clenv env list)",
      "Read(*)"
    ],
    "ask": [
      "Bash(git push:*)", "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)", "Bash(sudo rm:*)",
      "Read(./.env)", "Read(./.env.*)", "Read(**/secrets/**)", "Read(**/*.pem)"
    ]
  }
}
