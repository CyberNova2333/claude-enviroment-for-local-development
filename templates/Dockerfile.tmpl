# 由 `clenv init --docker` 生成。此镜像内置 clenv 工具箱与所选环境；
# 运行时把宿主机的项目目录挂载到 /workspace，改动即时可见，容器退出即弃（安全可控）。
# 修改本文件后，`clenv docker run/build` 会检测到变化并自动重建镜像。
FROM __BASE_IMAGE__

ENV DEBIAN_FRONTEND=noninteractive
# 基础依赖：git/curl/python3/bash（clenv 与安装脚本所需）
RUN (apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates python3 bash xz-utils && rm -rf /var/lib/apt/lists/*) \
    || (command -v apk >/dev/null && apk add --no-cache git curl python3 bash) \
    || true

# 安装 clenv 工具箱（从仓库克隆并注册命令；不改 PATH rc、不装 Claude Code、不交互）
RUN git clone --depth 1 __REPO_URL__ /opt/clenv-repo \
    && bash /opt/clenv-repo/install.sh --no-path --no-claude --silent
ENV PATH="/root/.local/bin:${PATH}"

# 预装所选环境（由 --docker-envs 指定；为空则跳过）
__ENVS_RUN__

WORKDIR /workspace
CMD ["/bin/bash"]
